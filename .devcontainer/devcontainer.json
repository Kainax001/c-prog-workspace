{
    "name": "Unix C Environment",
    "build": {
        "dockerfile": "Dockerfile"
    },
    
    "runArgs": [
        "--name", "my-c-project-container"
    ],

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cmake-tools",
                "twxs.cmake",
                "albert.tabout"
            ]
        }
    }
}